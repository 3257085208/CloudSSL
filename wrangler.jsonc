{
  "name": "cloudssl",
  "compatibility_date": "2026-04-15",
  "pages_build_output_dir": "public",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "acme_platform",
      "database_id": "你的D1数据库ID"
    }
  ],
  "r2_buckets": [
    {
      "binding": "CERTS",
      "bucket_name": "acme-certs"
    }
  ],
  "vars": {
    "APP_NAME": "CloudSSL"
  }
}
